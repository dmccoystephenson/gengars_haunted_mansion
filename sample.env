# =============================================================================
# Gengar's Haunted Mansion — Environment Variables
# =============================================================================
# Copy this file to .env and update values before running:
#   cp sample.env .env
#
# WARNING: Never commit the .env file — it may contain secrets.
# =============================================================================

# ---------------------
# Application (Backend)
# ---------------------

# Port the Express API server listens on (optional, default: 5000)
PORT=5000

# Node environment (required for backend)
# Must NOT be "production" for the backend to listen on a port in Docker.
# Allowed values: development, test, docker
NODE_ENV=development

# ---------------------
# Database — MongoDB
# ---------------------

# MongoDB connection string (required)
# When running with Docker Compose, use the service name "mongo" as the host.
# Format: mongodb://<user>:<password>@<host>:<port>/<database>?authSource=admin
MONGO_URI=mongodb://gengar:change_me@mongo:27017/gengars_haunted_mansion?authSource=admin

# MongoDB root username used to initialize the database container (required)
MONGO_INITDB_ROOT_USERNAME=gengar

# MongoDB root password used to initialize the database container (required)
# Change this to a strong, unique password.
MONGO_INITDB_ROOT_PASSWORD=change_me

# ---------------------
# Frontend — Next.js
# ---------------------

# URL of the backend API as seen from the Next.js server container (required)
# When running with Docker Compose, use the backend service name "api".
REACT_APP_BACKEND_URL=http://api:5000
